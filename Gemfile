source "https://rubygems.org"

# GitHub Pages builds this site; the github-pages gem pins the matching Jekyll +
# plugin versions for a local `bundle exec jekyll serve` that mirrors prod.
gem "github-pages", group: :jekyll_plugins
gem "jekyll-feed"
gem "jekyll-seo-tag"

# Ruby 3.x no longer ships these as default gems.
gem "webrick", "~> 1.8"
